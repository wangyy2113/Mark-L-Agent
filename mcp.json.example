{
  "mcpServers": {
    "agent-feishu-mcp": {
      "type": "http",
      "url": "https://mcp.feishu.cn/mcp",
      "headers": {
        "X-Lark-MCP-Allowed-Tools": "create-doc,update-doc,fetch-doc,list-docs,get-comments,add-comments,get-user"
      }
    },
    "agent-feishu-mcp-uat": {
      "type": "http",
      "url": "https://mcp.feishu.cn/mcp/YOUR_PERSONAL_TOKEN"
    },
    "agent-feishu-project": {
      "type": "http",
      "url": "https://project.feishu.cn/mcp_server/v1",
      "headers": {
        "X-Mcp-Token": "YOUR_PROJECT_TOKEN"
      }
    },
    "agent-lark-mcp": {
      "command": "npx",
      "args": [
        "-y",
        "@larksuiteoapi/lark-mcp",
        "mcp",
        "-a", "YOUR_APP_ID",
        "-s", "YOUR_APP_SECRET",
        "--token-mode", "tenant_access_token",
        "-l", "zh"
      ]
    }
  }
}
