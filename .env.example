# Mark-L Agent 环境变量配置
# 复制为 .env 后填入实际值：cp .env.example .env
#
# 切换机器人：创建 .env.bot 文件覆盖飞书凭证（优先级高于 .env）
#   FEISHU_APP_ID=cli_xxx
#   FEISHU_APP_SECRET=yyy
#   BOT_OPEN_ID=ou_zzz
#   ADMIN_OPEN_ID=ou_aaa    （同一用户对不同应用的 open_id 不同）
# mcp.json 中的 YOUR_APP_ID / YOUR_APP_SECRET 会在启动时自动替换，无需手动改

# ── 必填：飞书凭证 ──
FEISHU_APP_ID=cli_xxxxxxxxxxxx
FEISHU_APP_SECRET=

# 飞书事件验证（如启用签名校验才需填写）
# FEISHU_VERIFICATION_TOKEN=
# FEISHU_ENCRYPT_KEY=

# ── 必填：Claude API ──
ANTHROPIC_API_KEY=sk-ant-

# API 代理地址（走代理/自建 gateway 时填写）
# ANTHROPIC_BASE_URL=https://your-gateway.example.com/

# 模型选择（默认 claude-opus-4-6）
# CLAUDE_MODEL=claude-opus-4-6

# ── LLM 模式 ──
# "claude" = Claude Agent SDK 全功能模式（默认）
# "lite"   = OpenAI 兼容 API 轻量模式（无 MCP、无历史、无流式）
# LLM_PROVIDER=claude

# ── Lite 模式配置（仅 LLM_PROVIDER=lite 时需要）──
# LITE_API_KEY=
# LITE_BASE_URL=
# LITE_MODEL=gemini-2.0-flash

# ── MCP 配置 ──
# 如果文件不存在，启动时会根据飞书凭证自动生成（仅 stdio 类型）
# MCP_CONFIG_PATH=./mcp.json

# ── 初始管理员 ──
# 飞书 open_id，首次启动时写入 permissions.json
# 不知道可先留空，启动后从 audit.log 的 sender= 字段获取
# ADMIN_OPEN_ID=ou_

# ── Bot 自身标识 ──
# Bot 的 open_id，用于群聊中正确剥离 @bot 提及
# 不知道可先留空，启动后在群聊 @bot 发消息，从日志获取：
#   grep "mention:" data/app.log | head -1
# BOT_OPEN_ID=ou_

# ── Bot 身份（可选，影响自我介绍）──
# BOT_NAME=Agent
# BOT_TAGLINE=研发团队的 AI 协作伙伴

# ── 业务项目路径（Dev/Ask agent 用）──
# 绝对路径推荐，默认 ./biz（相对于项目根目录）
# BIZ_BASE_PATH=/home/user/mark-l-agent-biz

# ── 飞书文档默认目录 token ──
# FEISHU_DOC_FOLDER_TOKEN=

# ── 飞书 MCP token ──
# 个人 token（feishu-mcp-uat），从飞书 MCP 平台获取，格式 mcp_xxx
# FEISHU_PERSONAL_TOKEN=mcp_
# 飞书项目 token（feishu-project），从飞书项目 MCP 设置获取，格式 m-xxx
# FEISHU_PROJECT_TOKEN=m-

# ── Session ──
# SESSION_TTL_SECONDS=86400
# SESSION_DB_PATH=./data/sessions.db
